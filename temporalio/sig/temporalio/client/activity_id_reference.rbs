module Temporalio
  class Client
    class ActivityIDReference
      attr_reader activity_id: String
      attr_reader activity_run_id: String?
      attr_reader workflow_id: String?
      attr_reader run_id: String?

      def initialize: (workflow_id: String, run_id: String?, activity_id: String) -> void

      def self.for_standalone: (activity_id: String, ?activity_run_id: String?) -> ActivityIDReference

      def standalone?: -> bool
    end
  end
end
